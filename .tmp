#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>

int arr[10] = {6, 28, 12, 496, 15, 20, 8128, 18, 24, 30};

int perfect_count = 0;

pthread_mutex_t lock;

int isPerfect(int n)
{
    int sum = 0;

    for (int i = 1; i < n; i++)
    {
        if (n % i == 0)
        {
            sum += i;
        }
    }

    return sum == n;
}

void* checkPerfect(void* arg)
{
    int num = *(int*)arg;

    if (isPerfect(num))
    {
        int* result = (int*)malloc(sizeof(int));

        *result = num;

        pthread_mutex_lock(&lock);

        perfect_count++;

        pthread_mutex_unlock(&lock);

        pthread_exit(result);
    }

    pthread_exit(NULL);
}

int main()
{
    pthread_t threads[10];

    pthread_mutex_init(&lock, NULL);

    for (int i = 0; i < 10; i++)
    {
        pthread_create(&threads[i], NULL,
                       checkPerfect, &arr[i]);
    }

    for (int i = 0; i < 10; i++)
    {
        int* result;

        pthread_join(threads[i], (void**)&result);

        if (result != NULL)
        {
            printf("Perfect Number = %d\n", *result);

            free(result);
        }
    }

    printf("Total Perfect Numbers = %d\n", perfect_count);

    pthread_mutex_destroy(&lock);

    return 0;
}


