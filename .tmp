#include <stdio.h>
#include <omp.h>

int main() {
    int a[10], b[10];

    #pragma omp parallel
    {
        #pragma omp for nowait
        for (int i = 0; i < 10; i++)
            a[i] = i * 2;

        #pragma omp for
        for (int i = 0; i < 10; i++)
            b[i] = a[i] * 5;
    }

    return 0;
}


