#include <mpi.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_SIZE 1000000

int main(int argc, char *argv[])
{
    int rank, size;
    int msg_size;

    MPI_Init(&argc, &argv);

    MPI_Comm_rank(MPI_COMM_WORLD, &rank);
    MPI_Comm_size(MPI_COMM_WORLD, &size);

    if (size != 3)
    {
        if (rank == 0)
        {
            printf("Please run with exactly 3 processes.\n");
        }

        MPI_Finalize();
        return 0;
    }

    msg_size = 1;

    while (msg_size <= MAX_SIZE)
    {
        char *buffer = (char *)malloc(msg_size);

        memset(buffer, 'A', msg_size);

        MPI_Barrier(MPI_COMM_WORLD);

        double start_time = MPI_Wtime();

        if (rank == 0)
        {
            MPI_Send(buffer, msg_size, MPI_CHAR, 1, 0, MPI_COMM_WORLD);

            MPI_Recv(buffer, msg_size, MPI_CHAR, 2, 0,
                     MPI_COMM_WORLD, MPI_STATUS_IGNORE);

            printf("Process 0 completed exchange for message size = %d bytes\n",
                   msg_size);
        }

        else if (rank == 1)
        {
            MPI_Recv(buffer, msg_size, MPI_CHAR, 0, 0,
                     MPI_COMM_WORLD, MPI_STATUS_IGNORE);

            MPI_Send(buffer, msg_size, MPI_CHAR, 2, 0, MPI_COMM_WORLD);
        }

        else if (rank == 2)
        {
            MPI_Recv(buffer, msg_size, MPI_CHAR, 1, 0,
                     MPI_COMM_WORLD, MPI_STATUS_IGNORE);

            MPI_Send(buffer, msg_size, MPI_CHAR, 0, 0, MPI_COMM_WORLD);
        }

        MPI_Barrier(MPI_COMM_WORLD);

        double end_time = MPI_Wtime();

        if (rank == 0)
        {
            printf("Time taken = %f seconds\n\n",
                   end_time - start_time);
        }

        free(buffer);

        msg_size *= 2;
    }

    MPI_Finalize();

    return 0;
}

