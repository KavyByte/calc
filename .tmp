#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>

void* square(void* arg)
{
    int num = *(int*)arg;

    int* result = (int*)malloc(sizeof(int));

    *result = num * num;

    pthread_exit(result);
}

int main()
{
    pthread_t threads[5];
    int numbers[5] = {1, 2, 3, 4, 5};

    int sum = 0;

    for (int i = 0; i < 5; i++)
    {
        pthread_create(&threads[i], NULL, square, &numbers[i]);
    }

    for (int i = 0; i < 5; i++)
    {
        int* result;

        pthread_join(threads[i], (void**)&result);

        printf("Square = %d\n", *result);

        sum += *result;

        free(result);
    }

    printf("Final Sum = %d\n", sum);

    return 0;
}

