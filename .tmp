#include <stdio.h>
#include <omp.h>

int main() {

    omp_lock_t mylock;

    omp_init_lock(&mylock);

    int shared_variable = 0;

    #pragma omp parallel
    {
        omp_set_lock(&mylock);

        shared_variable++;

        printf("Thread %d updated value to %d\n",
               omp_get_thread_num(),
               shared_variable);

        omp_unset_lock(&mylock);
    }

    omp_destroy_lock(&mylock);

    return 0;
}


