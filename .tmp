#include <stdio.h>
#include <omp.h>

int main() {
    int x[10], y[10];

    #pragma omp parallel
    {
        int mytid = omp_get_thread_num();

        x[mytid] = mytid * 2;

        #pragma omp barrier

        if (mytid < 9)
            y[mytid] = x[mytid] + x[mytid + 1];
    }

    return 0;
}

