#include <stdio.h>
#include <omp.h>

#define V 4
#define INF 99999

void printMatrix(int dist[V][V])
{
    printf("Shortest Distance Matrix:\n");

    for (int i = 0; i < V; i++)
    {
        for (int j = 0; j < V; j++)
        {
            if (dist[i][j] == INF)
                printf("INF ");
            else
                printf("%3d ", dist[i][j]);
        }

        printf("\n");
    }
}

void floydWarshall(int dist[V][V])
{
    for (int k = 0; k < V; k++)
    {
        #pragma omp parallel
        {
            #pragma omp single

            {
                for (int i = 0; i < V; i++)
                {
                    for (int j = 0; j < V; j++)
                    {
                        #pragma omp task firstprivate(i, j, k)
                        {
                            if (dist[i][k] != INF &&
                                dist[k][j] != INF &&
                                dist[i][k] + dist[k][j] < dist[i][j])
                            {
                                dist[i][j] =
                                    dist[i][k] + dist[k][j];
                            }
                        }
                    }
                }

                #pragma omp taskwait
            }
        }
    }
}

