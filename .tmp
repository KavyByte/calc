#include <stdio.h>
#include <omp.h>

int main() {

    omp_lock_t locka, lockb;

    omp_init_lock(&locka);
    omp_init_lock(&lockb);

    #pragma omp parallel sections
    {

        #pragma omp section
        {
            omp_set_lock(&locka);
            omp_set_lock(&lockb);

            printf("Thread 1 working\n");

            omp_unset_lock(&lockb);
            omp_unset_lock(&locka);
        }

        #pragma omp section
        {
            omp_set_lock(&locka);
            omp_set_lock(&lockb);

            printf("Thread 2 working\n");

            omp_unset_lock(&lockb);
            omp_unset_lock(&locka);
        }
    }

    omp_destroy_lock(&locka);
    omp_destroy_lock(&lockb);

    return 0;
}


